# Copy to .env on the server (optional: load with python-dotenv).
#
# --- Dashboard auth (pick ONE) ---
# Plain password (hashed in-memory at process start; rotate by changing env)
DASHBOARD_PASSWORD=change-me
# Or pass an Argon2id hash (recommended for production). Plain password ignored if set.
# Generate: python -c "from argon2 import PasswordHasher; print(PasswordHasher().hash('your-pass'))"
# DASHBOARD_PASSWORD_HASH=$argon2id$v=19$m=65536,t=3,p=4$...

# Required when FLASK_DEBUG is not 1 (generate with secrets.token_hex(48))
SECRET_KEY=generate-a-long-random-secret

# Session lifetime (hours)
SESSION_HOURS=10

# Set to 1 behind HTTPS reverse proxy so cookies are only sent over TLS
SESSION_COOKIE_SECURE=0

# Client IP: CF-Connecting-IP (Cloudflare) is used automatically when present.
# If not using Cloudflare, enable X-Forwarded-For only behind a trusted reverse proxy:
# TRUST_X_FORWARDED_FOR=1

# Download root (must stay inside this tree for the file browser / deletes)
DOWNLOAD_DIR=/home/youruser/torrents

# Max uncompressed size allowed when using “ZIP” on a folder (needs disk space for the stored .zip too)
# ZIP_FOLDER_MAX_BYTES=10737418240

# Persistent zip cache (default: sibling folder ".weedr-zip-store" next to DOWNLOAD_DIR’s parent)
# ZIP_STORAGE_DIR=/var/lib/torrent-server/zips
# Max concurrent background zip jobs (global)
# ZIP_MAX_CONCURRENT=2

# Shown in storage / “effective free” stats (not enforced when adding torrents)
# DISK_RESERVE_BYTES=536870912
# DISK_RESERVE_PERCENT=1.0

# --- qBittorrent-nox (BitTorrent; libtorrent) ---
# If QBITTORRENT_URL is unset, the app can auto-spawn qbittorrent-nox on Linux (see QBITTORRENT_AUTO_START).
# QBITTORRENT_URL=http://127.0.0.1:8080
# QBITTORRENT_USERNAME=admin
# QBITTORRENT_PASSWORD=
# Profile + resume data (auto-spawn writes config here). Docker: mount a volume on this path.
QBITTORRENT_STATE_DIR=/home/youruser/.cache/torrent-server
# Auto-start local daemon when URL unset (Linux default true; Windows default false unless set to 1)
# QBITTORRENT_AUTO_START=1
# When auto-spawned, allow Web API from localhost without login (binds WebUI to 127.0.0.1 only).
# QBITTORRENT_BYPASS_LOCAL_AUTH=1
# Optional fixed WebUI port when auto-spawning (otherwise an ephemeral localhost port is chosen).
# QBITTORRENT_WEBUI_PORT=8080
# QBITTORRENT_PORT_BASE=18080
# Optional: explicit path to qbittorrent-nox (set automatically if build.sh installed the static binary).
# QBITTORRENT_BIN=/home/you/.local/bin/qbittorrent-nox
# On Linux, build.sh downloads https://github.com/userdocs/qbittorrent-nox-static when no binary is on PATH (requires curl or wget).
# QBITTORRENT_SKIP_STATIC_INSTALL=1
# Extra trackers (comma-separated); default list still applied from trackers_best unless disabled upstream.
# QBITTORRENT_BT_TRACKERS=udp://tracker.opentrackr.org:1337/announce,...
# Same keys as legacy aria2 build — parsed as per-torrent download/upload caps (0 = unlimited).
ARIA2_MAX_DOWNLOAD_LIMIT=0
ARIA2_MAX_UPLOAD_LIMIT=0
ARIA2_SEED_TIME=0
ARIA2_SEED_RATIO=0
# Optional explicit caps in bytes/sec
# QBITTORRENT_MAX_DOWNLOAD_BPS=0
# QBITTORRENT_MAX_UPLOAD_BPS=0
# On first Web API login the app applies high-throughput session defaults (setPreferences). Skip if you manage qBittorrent yourself:
# QBITTORRENT_SKIP_THROUGHPUT_PREFS=1
# By default completed torrents do not seed (share ratio 0 → pause or remove). Allow normal seeding:
# QBITTORRENT_ALLOW_SEEDING=1
# When not allowing seeding: 0 = pause torrent when ratio reached, 1 = remove torrent from client (files kept on disk)
# QBITTORRENT_RATIO_LIMIT_ACTION=0
# Optional overrides (defaults are tuned for fast links; watch open-file limits on the host):
# QBITTORRENT_MAX_CONNEC=5000
# QBITTORRENT_MAX_CONNEC_PER_TORRENT=800
# QBITTORRENT_MAX_ACTIVE_DOWNLOADS=50
# QBITTORRENT_MAX_ACTIVE_TORRENTS=200
# QBITTORRENT_MAX_ACTIVE_UPLOADS=100
# QBITTORRENT_ASYNC_IO_THREADS=8
# QBITTORRENT_FILE_POOL_SIZE=500
# Prefer TCP only if uTP is slow on your network: QBITTORRENT_BT_PROTOCOL=tcp
# Legacy env name for extra trackers (comma-separated)
# ARIA2_BT_TRACKERS=

# After changing qBittorrent settings, restart the app (and any manually run qbittorrent-nox).

# Listen binding (Flask / gunicorn)
HOST=127.0.0.1
PORT=5000
FLASK_DEBUG=0

# Rate limit storage for multi-worker setups (default memory://)
# RATELIMIT_STORAGE_URI=memory://

# --- Ops / logging ---
# Deep health checks for load balancers: GET /health?deep=1 or set HEALTH_DEEP=1
# HEALTH_DEEP=0
# LOG_JSON=1
# LOG_LEVEL=INFO

# Restrict dashboard (and JSON APIs) by client IP/CIDR (comma-separated). Empty = allow all.
# DASHBOARD_ALLOWED_CIDRS=203.0.113.0/24,2001:db8::/32

# Zip jobs SQLite (default: ZIP_STORAGE_DIR/jobs.sqlite)
# ZIP_JOB_DB=/var/lib/torrent-server/zips/jobs.sqlite
# ZIP_MAX_AGE_DAYS=0
# ZIP_MAX_TOTAL_BYTES=0

# Signed download URLs (recommended for IDM/parallel Range — no session cookie).
# Also used to sign ?token= on finished ZIP downloads. Optional anonymous GET below is insecure.
# FILES_DOWNLOAD_TOKEN_SECRET=
# FILES_DOWNLOAD_TOKEN_MAX_AGE=604800
# DANGEROUS: allow unauthenticated GET /files/… and GET zip download without token (off by default).
# FILES_DOWNLOAD_ANONYMOUS=0
# Reverse proxy: do not strip Range/Accept-Ranges (IDM needs them). For nginx see proxy_force_ranges / buffering.

# Append-only audit JSONL (login, deletes, zips, torrent events when emitted)
# AUDIT_LOG_PATH=/var/log/torrent-server/audit.jsonl

# Webhook for Discord/Slack/generic POST (JSON body includes "event")
# NOTIFY_WEBHOOK_URL=

# --- Experimental RSS auto-grab (disabled by default; legal/abuse risk) ---
# ENABLE_RSS_GRABS=0
# RSS_FEED_URL=https://example.com/feed.xml
# RSS_POLL_SECONDS=900
# RSS_MAX_MAGNETS_PER_POLL=5
# RSS_PARENT_SUBDIR=
# RSS_STATE_DB=/path/to/rss_magnets.sqlite
