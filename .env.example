# Copy to .env on the server (optional: load with python-dotenv).
#
# --- Dashboard auth (pick ONE) ---
# Plain password (hashed in-memory at process start; rotate by changing env)
DASHBOARD_PASSWORD=change-me
# Or pass an Argon2id hash (recommended for production). Plain password ignored if set.
# Generate: python -c "from argon2 import PasswordHasher; print(PasswordHasher().hash('your-pass'))"
# DASHBOARD_PASSWORD_HASH=$argon2id$v=19$m=65536,t=3,p=4$...

# Required when FLASK_DEBUG is not 1 (generate with secrets.token_hex(48))
SECRET_KEY=generate-a-long-random-secret

# Session lifetime (hours)
SESSION_HOURS=10

# Set to 1 behind HTTPS reverse proxy so cookies are only sent over TLS
SESSION_COOKIE_SECURE=0

# Download root (must stay inside this tree for the file browser / deletes)
DOWNLOAD_DIR=/home/youruser/torrents

# --- aria2 daemon (managed by the app) ---
# Optional fixed RPC port; if unset a free localhost port is chosen and persisted.
# ARIA2_RPC_PORT=6800
# Optional fixed RPC secret; otherwise stored under ARIA2_STATE_DIR (chmod 600)
# ARIA2_RPC_SECRET=
# Tracker list (comma-separated)
# ARIA2_BT_TRACKERS=udp://tracker.opentrackr.org:1337/announce,...
# No seeding after the download finishes (seed-time=0 seconds; seed-ratio=0 disables ratio rule).
# BitTorrent still uploads pieces while you are leeching — that is normal and keeps speeds reasonable.
ARIA2_SEED_TIME=0
ARIA2_SEED_RATIO=0
# Max concurrent downloads in aria2
ARIA2_MAX_CONCURRENT=8
ARIA2_STATE_DIR=/home/youruser/.cache/torrent-server

# Throughput tuning (fast VPS / high link — BitTorrent is still limited by peers & swarm health)
# After changes: stop the old aria2 RPC process, then restart the app (e.g. pm2 restart).
# ARIA2_MAX_CONNECTION_PER_SERVER=64
# ARIA2_SPLIT=64
# ARIA2_MIN_SPLIT_SIZE=1M
# ARIA2_BT_MAX_PEERS=300
# ARIA2_BT_MAX_OPEN_FILES=1000
# ARIA2_DISK_CACHE=256M
# Set to 0 or off to disable in-memory piece cache
# ARIA2_DISK_CACHE=0

# Optional: path to aria2c if not on PATH
# ARIA2_BIN=/usr/bin/aria2c

# Listen binding (Flask / gunicorn)
HOST=127.0.0.1
PORT=5000
FLASK_DEBUG=0

# Rate limit storage for multi-worker setups (default memory://)
# RATELIMIT_STORAGE_URI=memory://
