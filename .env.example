# Copy to .env and adjust. Flask loads these if you use python-dotenv (optional).
#
# Required: password for the dashboard (plain text; hashed at startup)
DASHBOARD_PASSWORD=change-me

# Required for sessions (use a long random string)
SECRET_KEY=generate-a-long-random-secret

# Where aria2 writes files (must match downloader.sh DOWNLOAD_DIR if you changed it)
DOWNLOAD_DIR=/home/youruser/torrents

# Absolute path to downloader.sh on the server
DOWNLOADER_SCRIPT=/home/youruser/torrent-server/downloader.sh

# Listen binding (Flask dev server)
HOST=127.0.0.1
PORT=5000
